{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Score metrics + error event",
  "type": "object",
  "properties": {
    "metrics": {
      "type": "object",
      "required": ["total_scorable", "erroneous_units", "atomic_error_rate", "weighted_error_rate",
        "maximum_applicable_weighted_error", "root_cause_count", "symptom_count", "perfect", "invalid", "denominators"]
    },
    "error_event": {
      "type": "object",
      "required": ["error_id", "task_id", "skill", "category", "severity", "weight", "field", "expected", "observed", "evidence", "root_cause", "parent_error_id"]
    }
  }
}
