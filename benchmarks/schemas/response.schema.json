{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Model response (per skill)",
  "oneOf": [
    { "title": "build", "type": "object", "required": ["class", "abilityScores"] },
    { "title": "check", "type": "object", "required": ["findings"], "properties": { "findings": { "type": "array" } } },
    { "title": "lookup", "type": "object", "properties": { "items": { "type": "array" }, "not_found": { "type": "boolean" } } },
    { "title": "help", "type": "object", "properties": { "skill": { "type": "string" }, "steps": { "type": "array" } } }
  ]
}
